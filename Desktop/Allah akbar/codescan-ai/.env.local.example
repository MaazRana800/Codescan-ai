# Supabase (get from supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini (get from aistudio.google.com → API Keys)
# Free tier: 1,500 requests/day for Gemini 2.5 Flash
GEMINI_API_KEY=your_gemini_api_key

# GitHub OAuth (create at github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=any-random-string-you-make-up

# Lemon Squeezy (get from app.lemonsqueezy.com → Settings → API)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
LEMONSQUEEZY_VARIANT_PRO=your_variant_pro_id
LEMONSQUEEZY_VARIANT_TEAM=your_variant_team_id

# Resend (get from resend.com → API Keys)
RESEND_API_KEY=your_resend_api_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
